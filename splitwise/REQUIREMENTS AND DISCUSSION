### SplitStrategy (Strategy Pattern)

```python
class SplitStrategy(ABC):
    @abstractmethod
    def calculate_splits(self, amount: float, users: List[User], 
                         split_details: dict) -> List[Split]:
        pass

class EqualSplitStrategy(SplitStrategy):
    def calculate_splits(self, amount, users, split_details):
        per_person = amount / len(users)
        return [EqualSplit(user, per_person) for user in users]

class ExactSplitStrategy(SplitStrategy):
    def calculate_splits(self, amount, users, split_details):
        # split_details = {user_id: exact_amount}
        # Validate sum == amount
        pass

class PercentSplitStrategy(SplitStrategy):
    def calculate_splits(self, amount, users, split_details):
        # split_details = {user_id: percentage}
        # Validate sum == 100
        pass
```

