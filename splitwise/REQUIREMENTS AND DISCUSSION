### NotificationObserver (Observer Pattern)

```python
class NotificationObserver(ABC):
    @abstractmethod
    def notify(self, user: User, message: str):
        pass

class EmailNotification(NotificationObserver):
    def notify(self, user, message):
        print(f"📧 Email to {user.email}: {message}")

class SMSNotification(NotificationObserver):
    def notify(self, user, message):
        print(f"📱 SMS to {user.phone}: {message}")

class PushNotification(NotificationObserver):
    def notify(self, user, message):
        print(f"🔔 Push to {user.name}: {message}")
```

---

### NotificationService (Publisher)

```python
class NotificationService:
    observers: List[NotificationObserver]
    
    def add_observer(self, observer):
        self.observers.append(observer)
    
    def notify_expense_added(self, expense: Expense):
        for split in expense.splits:
            if split.user != expense.paid_by:
                message = f"{expense.paid_by.name} added {expense.description}. You owe ₹{split.amount}"
                for observer in self.observers:
                    observer.notify(split.user, message)
    
    def notify_settlement(self, payer: User, payee: User, amount: float):
        message = f"{payer.name} paid you ₹{amount}"
        for observer in self.observers:
            observer.notify(payee, message)
```

